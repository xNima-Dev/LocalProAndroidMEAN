<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A">

    <!-- Full Screen Map -->
    <fragment
        android:id="@+id/customerTrackingMap"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Top status bar overlay -->
    <LinearLayout
        android:id="@+id/topStatusBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#CC0F172A"
        android:paddingHorizontal="16dp"
        android:paddingVertical="16dp"
        app:layout_anchor="@id/customerTrackingMap"
        app:layout_anchorGravity="top">

        <ImageButton
            android:id="@+id/btnBackCustomerTracking"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_icon_circle"
            android:src="@android:drawable/ic_menu_revert"
            android:scaleType="centerInside"
            android:contentDescription="Back"
            app:tint="#00D2FF" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginHorizontal="16dp">

            <TextView
                android:id="@+id/tvTrackingStatusTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Locating Provider"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvTrackingStatusSub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Waiting for updates..."
                android:textColor="#94A3B8"
                android:textSize="13sp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvStatusChip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PENDING"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/bg_chip"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"/>
    </LinearLayout>

    <!-- Bottom Panel -->
    <androidx.cardview.widget.CardView
        android:id="@+id/bottomTrackingPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="24dp"
        app:cardBackgroundColor="#1E293B"
        app:cardElevation="16dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Drag Handle -->
            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:background="#334155"
                android:layout_marginBottom="16dp"/>

            <!-- Provider Info Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <!-- Avatar -->
                <FrameLayout
                    android:layout_width="56dp"
                    android:layout_height="56dp">

                    <View
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_avatar_circle"/>

                    <TextView
                        android:id="@+id/tvProviderInitialTracking"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="P"
                        android:textColor="@color/lp_cyan"
                        android:textSize="24sp"
                        android:textStyle="bold"/>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginHorizontal="16dp">

                    <TextView
                        android:id="@+id/tvProviderNameTracking"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Assigning..."
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvProviderCategoryTracking"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Service Category"
                        android:textColor="#94A3B8"
                        android:textSize="14sp"/>
                </LinearLayout>

                <ImageButton
                    android:id="@+id/btnCallProvider"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_phone_btn"
                    android:src="@android:drawable/ic_menu_call"
                    android:scaleType="centerInside"
                    app:tint="#FFFFFF"
                    android:contentDescription="Call Provider"/>
            </LinearLayout>

            <!-- ETA Strip -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_card_dark"
                android:padding="16dp"
                android:gravity="center"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvCustomerEta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#00D2FF"
                        android:textSize="28sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ETA (mins)"
                        android:textColor="#94A3B8"
                        android:textSize="12sp"/>
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="40dp"
                    android:background="#334155"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvCustomerDistance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#00D2FF"
                        android:textSize="28sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="km away"
                        android:textColor="#94A3B8"
                        android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Payment Confirmation (hidden until completed) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirmPayment"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="✅ CONFIRM PAYMENT"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#0F172A"
                android:backgroundTint="#00D2FF"
                app:cornerRadius="12dp"
                android:visibility="gone"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
