<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Full Screen Map -->
    <fragment
        android:id="@+id/customerTrackingMap"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Top status bar overlay -->
    <LinearLayout
        android:id="@+id/topStatusBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#CC0F0F1A"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        app:layout_anchor="@id/customerTrackingMap"
        app:layout_anchorGravity="top">

        <ImageButton
            android:id="@+id/btnBackCustomerTracking"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/bg_icon_circle"
            android:src="@android:drawable/ic_media_previous"
            android:scaleType="centerInside"
            android:contentDescription="Back"
            app:tint="#FFFFFF" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginHorizontal="12dp">

            <TextView
                android:id="@+id/tvTrackingStatusTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Provider is on the way"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"/>

            <TextView
                android:id="@+id/tvTrackingStatusSub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Waiting for update..."
                android:textColor="#AAAACC"
                android:textSize="12sp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvStatusChip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PENDING"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_info_pill"
            android:paddingHorizontal="10dp"
            android:paddingVertical="5dp"/>
    </LinearLayout>

    <!-- Bottom Panel -->
    <androidx.cardview.widget.CardView
        android:id="@+id/bottomTrackingPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="24dp"
        app:cardBackgroundColor="#0F0F1A"
        app:cardElevation="16dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Drag Handle -->
            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:background="#444466"
                android:layout_marginBottom="16dp"/>

            <!-- Provider Info Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <!-- Avatar -->
                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp">

                    <View
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_avatar_circle"/>

                    <TextView
                        android:id="@+id/tvProviderInitialTracking"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="P"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:fontFamily="sans-serif-medium"/>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginHorizontal="12dp">

                    <TextView
                        android:id="@+id/tvProviderNameTracking"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Provider Name"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:id="@+id/tvProviderCategoryTracking"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Category"
                        android:textColor="#A855F7"
                        android:textSize="12sp"/>
                </LinearLayout>

                <ImageButton
                    android:id="@+id/btnCallProvider"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_phone_btn"
                    android:src="@android:drawable/ic_menu_call"
                    android:scaleType="centerInside"
                    android:tint="#FFFFFF"
                    android:contentDescription="Call Provider"/>
            </LinearLayout>

            <!-- ETA Strip -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_card_dark"
                android:padding="16dp"
                android:gravity="center"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvCustomerEta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#7C3AED"
                        android:textSize="24sp"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ETA (mins)"
                        android:textColor="#888899"
                        android:textSize="11sp"/>
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="40dp"
                    android:background="#333344"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvCustomerDistance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#06B6D4"
                        android:textSize="24sp"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="km away"
                        android:textColor="#888899"
                        android:textSize="11sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Payment Confirmation (hidden until completed) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirmPayment"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="✅ Confirm Payment"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"
                android:backgroundTint="#16A34A"
                app:cornerRadius="14dp"
                android:visibility="gone"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
