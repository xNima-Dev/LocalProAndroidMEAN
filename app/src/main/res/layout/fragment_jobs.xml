<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/lp_bg_deep"
        android:fitsSystemWindows="true">

        <!-- ===== HEADER ===== -->
        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/jobsAppBarLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/gradient_header_bg"
            android:elevation="0dp"
            app:elevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="48dp"
                android:paddingBottom="16dp">

                <!-- Title row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="My Jobs"
                            android:textColor="@color/lp_text_primary"
                            android:textSize="26sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Track your active &amp; past work"
                            android:textColor="@color/lp_text_secondary"
                            android:textSize="13sp"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                    <!-- Job count badge -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/gradient_card_blue"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvTotalActiveJobs"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3"
                            android:textColor="@color/white"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Active"
                            android:textColor="#BAE6FD"
                            android:textSize="10sp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- ===== FILTER TABS ===== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/bg_card_dark"
                    android:padding="4dp"
                    android:orientation="horizontal">

                    <!-- Active Tab -->
                    <TextView
                        android:id="@+id/tabActive"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="36dp"
                        android:gravity="center"
                        android:text="Active"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:background="@drawable/gradient_card_blue"
                        android:clickable="true"
                        android:focusable="true" />

                    <!-- Completed Tab -->
                    <TextView
                        android:id="@+id/tabCompleted"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="36dp"
                        android:gravity="center"
                        android:text="Completed"
                        android:textColor="@color/lp_text_muted"
                        android:textSize="13sp"
                        android:clickable="true"
                        android:focusable="true" />

                    <!-- Cancelled Tab -->
                    <TextView
                        android:id="@+id/tabCancelled"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="36dp"
                        android:gravity="center"
                        android:text="Cancelled"
                        android:textColor="@color/lp_text_muted"
                        android:textSize="13sp"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.appbar.AppBarLayout>

        <!-- ===== SCROLLABLE CONTENT ===== -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/jobsScrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="90dp"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- ===== IN PROGRESS JOB CARD ===== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_online_card"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Status Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#128736;&#65039;"
                            android:textSize="18sp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="IN PROGRESS"
                            android:textColor="@color/lp_cyan"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:paddingStart="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_status_online"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:text="LIVE"
                            android:textColor="@color/white"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1" />

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="12dp"
                        android:background="@color/lp_border" />

                    <!-- Job Title -->
                    <TextView
                        android:id="@+id/tvActiveJobTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Electrical Wiring Fix"
                        android:textColor="@color/lp_text_primary"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <!-- Customer -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#128100;"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvActiveJobCustomer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" Amara Perera"
                            android:textColor="@color/lp_text_secondary"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="  &#8226;  "
                            android:textColor="@color/lp_text_muted"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#128205;"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvActiveJobLocation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" Colombo 5"
                            android:textColor="@color/lp_text_secondary"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <!-- Time and Earning Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Started"
                                android:textColor="@color/lp_text_muted"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tvActiveJobStartTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="10:30 AM"
                                android:textColor="@color/lp_text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Estimated"
                                android:textColor="@color/lp_text_muted"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tvActiveJobEarning"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="LKR 3,500"
                                android:textColor="@color/lp_green"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <!-- Complete Button -->
                        <LinearLayout
                            android:id="@+id/btnMarkComplete"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_btn_accept"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:clickable="true"
                            android:focusable="true">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="&#10003;  "
                                android:textColor="@color/lp_green"
                                android:textSize="12sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Complete"
                                android:textColor="@color/lp_green"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

                <!-- ===== PENDING JOB CARD ===== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_card_dark"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Status Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#9203;"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="CONFIRMED"
                            android:textColor="@color/lp_amber"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:paddingStart="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/gradient_card_amber"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:text="Tomorrow"
                            android:textColor="@color/white"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="12dp"
                        android:background="@color/lp_border" />

                    <TextView
                        android:id="@+id/tvPendingJobTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Plumbing Repair - Kitchen Sink"
                        android:textColor="@color/lp_text_primary"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#128100;"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvPendingJobCustomer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" Nimal Silva"
                            android:textColor="@color/lp_text_secondary"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="  &#8226;  "
                            android:textColor="@color/lp_text_muted"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#128197; "
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvPendingJobDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Jun 27 at 9:00 AM"
                            android:textColor="@color/lp_text_secondary"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Quoted"
                                android:textColor="@color/lp_text_muted"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tvPendingJobEarning"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="LKR 2,800"
                                android:textColor="@color/lp_green"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/btnStartJob"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:background="@drawable/gradient_card_blue"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:clickable="true"
                            android:focusable="true">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="&#9654;  "
                                android:textColor="@color/white"
                                android:textSize="12sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Start Job"
                                android:textColor="@color/white"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

                <!-- ===== SECTION TITLE: COMPLETED ===== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Recently Completed"
                        android:textColor="@color/lp_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="See all"
                        android:textColor="@color/lp_cyan"
                        android:textSize="13sp" />

                </LinearLayout>

                <!-- ===== COMPLETED JOB CARD 1 ===== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_card_dark"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#9989;"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="COMPLETED"
                            android:textColor="@color/lp_green"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:paddingStart="8dp" />

                        <TextView
                            android:id="@+id/tvCompletedJob1Earning"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="LKR 4,200"
                            android:textColor="@color/lp_green"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="12dp"
                        android:background="@color/lp_border" />

                    <TextView
                        android:id="@+id/tvCompletedJob1Title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AC Installation &amp; Servicing"
                        android:textColor="@color/lp_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#128100; Kasun Jayawardena  &#8226;  &#128197; Jun 25, 2026"
                            android:textColor="@color/lp_text_secondary"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <!-- Rating row -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#11088;&#11088;&#11088;&#11088;&#11088;"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="  5.0"
                            android:textColor="@color/lp_amber"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

                <!-- ===== COMPLETED JOB CARD 2 ===== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_card_dark"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#9989;"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="COMPLETED"
                            android:textColor="@color/lp_green"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:paddingStart="8dp" />

                        <TextView
                            android:id="@+id/tvCompletedJob2Earning"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="LKR 1,800"
                            android:textColor="@color/lp_green"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="12dp"
                        android:background="@color/lp_border" />

                    <TextView
                        android:id="@+id/tvCompletedJob2Title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bathroom Tile Repair"
                        android:textColor="@color/lp_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#128100; Dilupa Fernando  &#8226;  &#128197; Jun 24, 2026"
                            android:textColor="@color/lp_text_secondary"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#11088;&#11088;&#11088;&#11088;"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="  4.0"
                            android:textColor="@color/lp_amber"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

                <!-- ===== RECYCLER PLACEHOLDER ===== -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvJobsList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:visibility="gone" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</layout>