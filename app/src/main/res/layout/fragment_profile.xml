<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/lp_bg_deep"
        android:fitsSystemWindows="true">

        <!-- ===== HEADER ===== -->
        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/profileAppBarLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/gradient_header_bg"
            android:elevation="0dp"
            app:elevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="48dp"
                android:paddingBottom="20dp">

                <!-- Title Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="My Profile"
                        android:textColor="@color/lp_text_primary"
                        android:textSize="26sp"
                        android:textStyle="bold" />

                    <!-- Edit Button -->
                    <LinearLayout
                        android:id="@+id/btnEditProfile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_quick_action"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="10dp"
                        android:paddingBottom="10dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#9998;  "
                            android:textColor="@color/lp_cyan"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Edit"
                            android:textColor="@color/lp_cyan"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

                <!-- ===== PROFILE CARD ===== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/bg_card_dark"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <!-- Avatar -->
                    <FrameLayout
                        android:layout_width="72dp"
                        android:layout_height="72dp">

                        <View
                            android:layout_width="72dp"
                            android:layout_height="72dp"
                            android:background="@drawable/bg_avatar_circle" />

                        <View
                            android:layout_width="72dp"
                            android:layout_height="72dp"
                            android:background="@drawable/bg_icon_circle"
                            android:alpha="0.25" />

                        <TextView
                            android:id="@+id/tvProfileInitials"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="JD"
                            android:textColor="@color/lp_cyan"
                            android:textSize="26sp"
                            android:textStyle="bold" />

                    </FrameLayout>

                    <!-- Name & info -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="16dp">

                        <TextView
                            android:id="@+id/tvProfileName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="John Doe"
                            android:textColor="@color/lp_text_primary"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvProfileCategory"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#128295; Electrician"
                            android:textColor="@color/lp_cyan"
                            android:textSize="13sp"
                            android:layout_marginTop="4dp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="4dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="&#11088; 4.8"
                                android:textColor="@color/lp_amber"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="  (47 reviews)"
                                android:textColor="@color/lp_text_muted"
                                android:textSize="12sp" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Verified Badge -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/gradient_card_green"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#9989;"
                            android:textSize="16sp"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Verified"
                            android:textColor="@color/white"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.appbar.AppBarLayout>

        <!-- ===== SCROLLABLE CONTENT ===== -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/profileScrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="90dp"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- ===== QUICK STATS ROW ===== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_card_dark"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#127942;"
                            android:textSize="22sp" />

                        <TextView
                            android:id="@+id/tvStatJobsDone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="47"
                            android:textColor="@color/lp_text_primary"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Jobs Done"
                            android:textColor="@color/lp_text_muted"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_card_dark"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#11088;"
                            android:textSize="22sp" />

                        <TextView
                            android:id="@+id/tvStatRating"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="4.8"
                            android:textColor="@color/lp_text_primary"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rating"
                            android:textColor="@color/lp_text_muted"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/bg_card_dark"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#128197;"
                            android:textSize="22sp" />

                        <TextView
                            android:id="@+id/tvStatMemberSince"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="6 mo"
                            android:textColor="@color/lp_text_primary"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Active"
                            android:textColor="@color/lp_text_muted"
                            android:textSize="11sp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- ===== PERSONAL DETAILS SECTION ===== -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Personal Details"
                    android:textColor="@color/lp_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_dark"
                    android:orientation="vertical"
                    android:layout_marginBottom="20dp">

                    <!-- Phone -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp">

                        <FrameLayout
                            android:layout_width="38dp"
                            android:layout_height="38dp">

                            <View
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:background="@drawable/bg_icon_circle"
                                android:alpha="0.2" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="&#128222;"
                                android:textSize="16sp" />

                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingStart="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Phone"
                                android:textColor="@color/lp_text_muted"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tvProfilePhone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="+94 77 123 4567"
                                android:textColor="@color/lp_text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#8250;"
                            android:textColor="@color/lp_text_muted"
                            android:textSize="22sp" />

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="68dp"
                        android:background="@color/lp_border" />

                    <!-- Email -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp">

                        <FrameLayout
                            android:layout_width="38dp"
                            android:layout_height="38dp">

                            <View
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:background="@drawable/bg_icon_circle"
                                android:alpha="0.2" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="&#9993;"
                                android:textSize="16sp" />

                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingStart="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Email"
                                android:textColor="@color/lp_text_muted"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tvProfileEmail"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="john.doe@localpro.lk"
                                android:textColor="@color/lp_text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#8250;"
                            android:textColor="@color/lp_text_muted"
                            android:textSize="22sp" />

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="68dp"
                        android:background="@color/lp_border" />

                    <!-- Location -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp">

                        <FrameLayout
                            android:layout_width="38dp"
                            android:layout_height="38dp">

                            <View
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:background="@drawable/bg_icon_circle"
                                android:alpha="0.2" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="&#128205;"
                                android:textSize="16sp" />

                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingStart="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Service Area"
                                android:textColor="@color/lp_text_muted"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tvProfileLocation"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Colombo, Sri Lanka"
                                android:textColor="@color/lp_text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#8250;"
                            android:textColor="@color/lp_text_muted"
                            android:textSize="22sp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- ===== BIO SECTION ===== -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bio"
                    android:textColor="@color/lp_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_dark"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:id="@+id/tvProfileBio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Experienced electrician with over 5 years in residential and commercial wiring, AC installation, and fault diagnosis. Available 7 days a week. Based in Colombo."
                        android:textColor="@color/lp_text_secondary"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.4" />

                </LinearLayout>

                <!-- ===== SETTINGS SECTION ===== -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Settings"
                    android:textColor="@color/lp_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_dark"
                    android:orientation="vertical"
                    android:layout_marginBottom="20dp">

                    <!-- Notifications -->
                    <LinearLayout
                        android:id="@+id/settingNotifications"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="38dp"
                            android:layout_height="38dp">

                            <View
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:background="@drawable/bg_icon_circle"
                                android:alpha="0.15" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="&#128276;"
                                android:textSize="16sp" />

                        </FrameLayout>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Notifications"
                            android:textColor="@color/lp_text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:paddingStart="14dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#8250;"
                            android:textColor="@color/lp_text_muted"
                            android:textSize="22sp" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="68dp"
                        android:background="@color/lp_border" />

                    <!-- Security -->
                    <LinearLayout
                        android:id="@+id/settingSecurity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="38dp"
                            android:layout_height="38dp">

                            <View
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:background="@drawable/bg_icon_circle"
                                android:alpha="0.15" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="&#128274;"
                                android:textSize="16sp" />

                        </FrameLayout>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Security &amp; Password"
                            android:textColor="@color/lp_text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:paddingStart="14dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#8250;"
                            android:textColor="@color/lp_text_muted"
                            android:textSize="22sp" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="68dp"
                        android:background="@color/lp_border" />

                    <!-- Help & Support -->
                    <LinearLayout
                        android:id="@+id/settingSupport"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="38dp"
                            android:layout_height="38dp">

                            <View
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:background="@drawable/bg_icon_circle"
                                android:alpha="0.15" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="&#128172;"
                                android:textSize="16sp" />

                        </FrameLayout>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Help &amp; Support"
                            android:textColor="@color/lp_text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:paddingStart="14dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#8250;"
                            android:textColor="@color/lp_text_muted"
                            android:textSize="22sp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- ===== LOGOUT BUTTON ===== -->
                <LinearLayout
                    android:id="@+id/btnLogoutProvider"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/bg_btn_decline"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#128682;  "
                        android:textColor="@color/lp_red"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sign Out"
                        android:textColor="@color/lp_red"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                </LinearLayout>

                <!-- App version -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="LocalPro v1.0.0  &#8226;  Made with &#10084;&#65039; in Sri Lanka"
                    android:textColor="@color/lp_text_muted"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:layout_marginTop="8dp" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</layout>