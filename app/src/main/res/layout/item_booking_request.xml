<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_card_dark"
    android:backgroundTint="#1E293B"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Row 1: Customer name + Time badge -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Customer Avatar -->
        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp">

            <View
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_avatar_circle" />

            <TextView
                android:id="@+id/tvCustomerInitial"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="C"
                android:textColor="#00D2FF"
                android:textSize="20sp"
                android:textStyle="bold" />
        </FrameLayout>

        <!-- Customer Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp">

            <TextView
                android:id="@+id/tvCustomerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Customer Name"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#128205;"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/tvCustomerDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1.2 km away"
                    android:textColor="#00D2FF"
                    android:textSize="12sp"
                    android:paddingStart="4dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Time Badge -->
        <TextView
            android:id="@+id/tvRequestTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chip"
            android:backgroundTint="#334155"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="Just now"
            android:textColor="#94A3B8"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#334155"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp" />

    <!-- Row 2: Job Description -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Job Description"
            android:textColor="#94A3B8"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvJobDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Need help fixing a leaky pipe in the kitchen..."
            android:textColor="#E2E8F0"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            android:maxLines="2"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Row 3: Estimated Earning & Category -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Est. Earning"
                android:textColor="#94A3B8"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvEstimatedEarning"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LKR 1,500"
                android:textColor="#10B981"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>
        
        <TextView
            android:id="@+id/tvServiceCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Plumbing"
            android:textColor="#00D2FF"
            android:textSize="12sp"
            android:background="@drawable/bg_chip"
            android:backgroundTint="#1A00D2FF"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp" />
    </LinearLayout>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp"
        android:weightSum="2">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDecline"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:text="DECLINE"
            android:textColor="#F87171"
            app:strokeColor="#F87171"
            app:cornerRadius="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAccept"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:text="ACCEPT"
            android:textColor="#0F172A"
            android:textStyle="bold"
            app:backgroundTint="#00D2FF"
            app:cornerRadius="8dp" />
    </LinearLayout>

</LinearLayout>
