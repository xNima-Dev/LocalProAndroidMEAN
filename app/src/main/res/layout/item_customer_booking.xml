<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="#1E293B"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Avatar -->
        <View
            android:id="@+id/imgProviderAvatar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_avatar_circle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvProviderInitial"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:gravity="center"
            android:text="P"
            android:textColor="@color/lp_cyan"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="@id/imgProviderAvatar"
            app:layout_constraintBottom_toBottomOf="@id/imgProviderAvatar"
            app:layout_constraintStart_toStartOf="@id/imgProviderAvatar"
            app:layout_constraintEnd_toEndOf="@id/imgProviderAvatar" />

        <!-- Details -->
        <TextView
            android:id="@+id/tvBookingProviderName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Provider Name"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/imgProviderAvatar"
            app:layout_constraintTop_toTopOf="@id/imgProviderAvatar"
            app:layout_constraintEnd_toStartOf="@id/tvBookingStatus"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/tvBookingCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Plumbing Specialist"
            android:textColor="#94A3B8"
            android:textSize="13sp"
            app:layout_constraintStart_toStartOf="@id/tvBookingProviderName"
            app:layout_constraintTop_toBottomOf="@id/tvBookingProviderName" />

        <!-- Status Pill -->
        <TextView
            android:id="@+id/tvBookingStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chip"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:text="Pending"
            android:textColor="#FBBF24"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/imgProviderAvatar"
            app:layout_constraintBottom_toBottomOf="@id/imgProviderAvatar" />

        <View
            android:id="@+id/divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#334155"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/imgProviderAvatar"/>
            
        <TextView
            android:id="@+id/tvBookingDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Requested on 12 Oct 2026, 10:30 AM"
            android:textColor="#64748B"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/divider" />
            
        <TextView
            android:id="@+id/tvActionText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="View Details ➔"
            android:textColor="#00D2FF"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvBookingDate"
            app:layout_constraintBottom_toBottomOf="@id/tvBookingDate"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
