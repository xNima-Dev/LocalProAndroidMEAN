<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="#1E293B"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Avatar -->
        <View
            android:id="@+id/imgAvatar"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_avatar_circle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Verification Badge over Avatar -->
        <ImageView
            android:id="@+id/ivVerified"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@android:drawable/checkbox_on_background"
            app:tint="#00D2FF"
            app:layout_constraintBottom_toBottomOf="@id/imgAvatar"
            app:layout_constraintEnd_toEndOf="@id/imgAvatar"
            android:layout_marginEnd="-4dp"
            android:layout_marginBottom="-4dp" />

        <TextView
            android:id="@+id/tvAvatarInitial"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:gravity="center"
            android:text="P"
            android:textColor="@color/lp_cyan"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="@id/imgAvatar"
            app:layout_constraintBottom_toBottomOf="@id/imgAvatar"
            app:layout_constraintStart_toStartOf="@id/imgAvatar"
            app:layout_constraintEnd_toEndOf="@id/imgAvatar" />

        <!-- Details -->
        <TextView
            android:id="@+id/itemProviderName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Provider Name"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/imgAvatar"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnBookNow"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/itemProviderRating"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="⭐ 4.8 (120)"
            android:textColor="#FBBF24"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/itemProviderName"
            app:layout_constraintTop_toBottomOf="@id/itemProviderName" />

        <TextView
            android:id="@+id/itemProviderRate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="LKR 1,500/hr"
            android:textColor="#94A3B8"
            android:textSize="13sp"
            app:layout_constraintStart_toStartOf="@id/itemProviderName"
            app:layout_constraintTop_toBottomOf="@id/itemProviderRating" />
            
        <TextView
            android:id="@+id/itemProviderDistance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="• 2.5 km away"
            android:textColor="#94A3B8"
            android:textSize="13sp"
            app:layout_constraintStart_toEndOf="@id/itemProviderRate"
            app:layout_constraintBottom_toBottomOf="@id/itemProviderRate" />

        <!-- Book Now Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBookNow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#00D2FF"
            android:text="BOOK"
            android:textColor="#0F172A"
            android:textStyle="bold"
            app:cornerRadius="20dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>