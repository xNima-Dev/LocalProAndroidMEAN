<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_dark"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="16dp"
    android:layout_marginBottom="8dp">

    <!-- Icon -->
    <FrameLayout
        android:layout_width="44dp"
        android:layout_height="44dp">

        <View
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_icon_circle"
            android:alpha="0.2" />

        <TextView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="&#128176;"
            android:textSize="20sp" />
    </FrameLayout>

    <!-- Details -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="14dp">

        <TextView
            android:id="@+id/tvTransactionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Payment Received"
            android:textColor="@color/lp_text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTransactionSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Jun 23, 2026  &#8226;  Customer Name"
            android:textColor="@color/lp_text_secondary"
            android:textSize="11sp"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <!-- Amount & Status -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">

        <TextView
            android:id="@+id/tvTransactionAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+LKR 1,800"
            android:textColor="@color/lp_green"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTransactionStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Completed"
            android:textColor="@color/lp_text_secondary"
            android:textSize="11sp"
            android:layout_marginTop="2dp" />

    </LinearLayout>

</LinearLayout>
